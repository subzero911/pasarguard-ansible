#!/bin/bash
# Скрипт восстановления PasarGuard из бэкапа Google Drive
set -euo pipefail

RCLONE_REMOTE="{{ rclone_gdrive_remote }}"
STACK_DIR="{{ pasarguard_stack_dir }}"
PASARGUARD_DATA="{{ pasarguard_data_dir }}"
COMPOSE_PROJECT=$(basename "${STACK_DIR}")
TEMP_DIR="/tmp/restore-pasarguard-$$"
LOG_FILE="/var/log/restore-pasarguard.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

error_exit() {
    log "ОШИБКА: $*"
    exit 1
}

# ─── Показать список бэкапов ──────────────────────────────────────────────────

log "=== Получение списка бэкапов из Google Drive ==="
rclone ls "${RCLONE_REMOTE}/" || error_exit "Не удалось получить список бэкапов"

echo ""
echo "Доступные бэкапы:"
rclone ls "${RCLONE_REMOTE}/" | awk '{print $2}' | sort -r
echo ""

LATEST_BACKUP=$(rclone ls "${RCLONE_REMOTE}/" | awk '{print $2}' | sort -r | head -1)

# ─── Запросить имя файла ───────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
    read -p "Введите имя файла бэкапа (Enter = последний: ${LATEST_BACKUP}): " BACKUP_FILE
    if [[ -z "${BACKUP_FILE}" ]]; then
        BACKUP_FILE="${LATEST_BACKUP}"
        log "Выбран последний бэкап: ${BACKUP_FILE}"
    fi
else
    BACKUP_FILE="$1"
fi

if [[ -z "${BACKUP_FILE}" ]]; then
    error_exit "Бэкапы не найдены в ${RCLONE_REMOTE}"
fi

# ─── Скачать бэкап ───────────────────────────────────────────────────────────

log "Скачивание ${BACKUP_FILE}..."
mkdir -p "${TEMP_DIR}"
rclone copy "${RCLONE_REMOTE}/${BACKUP_FILE}" "${TEMP_DIR}/" || error_exit "Не удалось скачать бэкап"

ARCHIVE_PATH="${TEMP_DIR}/${BACKUP_FILE}"

if [[ ! -f "${ARCHIVE_PATH}" ]]; then
    error_exit "Архив не найден после скачивания"
fi

ARCHIVE_SIZE=$(du -sh "${ARCHIVE_PATH}" | cut -f1)
log "Размер архива: ${ARCHIVE_SIZE}"

# ─── Распаковка ───────────────────────────────────────────────────────────────

log "Распаковка архива..."
tar -xzf "${ARCHIVE_PATH}" -C "${TEMP_DIR}"

BACKUP_CONTENT_DIR=$(find "${TEMP_DIR}" -maxdepth 1 -type d -name "pasarguard_backup_*" | head -1)

if [[ -z "${BACKUP_CONTENT_DIR}" ]]; then
    error_exit "Не найдена директория с бэкапом в архиве"
fi

log "Содержимое бэкапа:"
ls -la "${BACKUP_CONTENT_DIR}"

# ─── Предупреждение ─────────────────────────────────────────────────────────

echo ""
echo "══════════════════════════════════════════════════════════════"
echo "ВНИМАНИЕ: Процедура восстановления:"
echo "  1. Будет остановлен docker-compose стек"
echo "  2. Данные будут восстановлены из бэкапа"
echo "  3. Стек будет запущен заново"
echo "══════════════════════════════════════════════════════════════"
echo ""
read -p "Продолжить? (yes/no): " CONFIRM

if [[ "${CONFIRM}" != "yes" ]]; then
    log "Отмена восстановления пользователем"
    rm -rf "${TEMP_DIR}"
    exit 0
fi

# ─── Создание структуры директорий ─────────────────────────────────────────────

log "Создание структуры директорий..."
mkdir -p "${PASARGUARD_DATA}"
mkdir -p "${STACK_DIR}"
log "Директории созданы: ${PASARGUARD_DATA}, ${STACK_DIR}"

# ─── Остановка docker-compose ─────────────────────────────────────────────────

log "Остановка docker-compose стека..."
cd "${STACK_DIR}"
docker compose down || error_exit "Не удалось остановить docker-compose"

# ─── Восстановление Docker volumes ────────────────────────────────────────────

log "Восстановление Docker volumes..."
for VOL_FILE in "${BACKUP_CONTENT_DIR}"/volumes/*.tar.gz; do
    if [[ -f "${VOL_FILE}" ]]; then
        VOL_NAME=$(basename "${VOL_FILE}" .tar.gz)
        FULL_VOL="${COMPOSE_PROJECT}_${VOL_NAME}"
        log "Восстановление Docker volume: ${FULL_VOL}..."
        docker volume rm -f "${FULL_VOL}" || true
        docker volume create "${FULL_VOL}" || true
        docker run --rm -v "${FULL_VOL}:/target" -v "${BACKUP_CONTENT_DIR}/volumes:/backup" busybox sh -c "cd /target && tar xzf /backup/${VOL_NAME}.tar.gz"
        log "Volume ${FULL_VOL} восстановлен"
    fi
done

# ─── Восстановление базы данных ───────────────────────────────────────────────

log "Восстановление базы данных PostgreSQL..."
if [[ -f "${BACKUP_CONTENT_DIR}/postgres_dump.sql.gz" ]]; then
    log "Запуск контейнера postgres..."
    cd "${STACK_DIR}"
    docker compose up -d postgres
    sleep 5
    log "Восстановление дампа..."
    gunzip -c "${BACKUP_CONTENT_DIR}/postgres_dump.sql.gz" | \
        docker compose exec -T postgres psql -U pasarguard -d pasarguard
    log "База данных PostgreSQL восстановлена"
else
    log "Дамп PostgreSQL не найден в архиве, пропускаем"
fi

# ─── Восстановление данных PasarGuard ────────────────────────────────────────

log "Восстановление данных PasarGuard..."
if [[ -d "${BACKUP_CONTENT_DIR}/pasarguard-data" ]]; then
    rsync -a "${BACKUP_CONTENT_DIR}/pasarguard-data/" "${PASARGUARD_DATA}/"
    log "Данные PasarGuard восстановлены"
else
    log "Директория pasarguard-data не найдена, пропускаем"
fi

# ─── Восстановление конфигурации стека ────────────────────────────────────────

log "Восстановление конфигурации стека..."
if [[ -d "${BACKUP_CONTENT_DIR}/pasarguard-stack" ]]; then
    rsync -a "${BACKUP_CONTENT_DIR}/pasarguard-stack/" "${STACK_DIR}/"
    log "Конфигурация стека восстановлена"
else
    log "Директория pasarguard-stack не найдена, пропускаем"
fi

# ─── Запуск docker-compose ───────────────────────────────────────────────────

log "Запуск docker-compose стека..."
cd "${STACK_DIR}"
docker compose up -d || error_exit "Не удалось запустить docker-compose"

# ─── Очистка ────────────────────────────────────────────────────────────────

rm -rf "${TEMP_DIR}"

log "=== Восстановление завершено успешно ==="
log "Проверьте статус контейнеров: cd ${STACK_DIR} && docker compose ps"
