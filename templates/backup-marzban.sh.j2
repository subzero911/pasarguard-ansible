#!/bin/bash
# Скрипт бэкапа Marzban → Google Drive (через rclone)
set -euo pipefail

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_NAME="marzban_backup_${TIMESTAMP}"
TEMP_DIR="/tmp/${BACKUP_NAME}"
RCLONE_REMOTE="{{ rclone_gdrive_remote }}"
KEEP_DAYS="{{ backup_keep_days }}"
STACK_DIR="{{ marzban_stack_dir }}"
MARZBAN_DATA="{{ marzban_data_dir }}"
LOG_FILE="/var/log/backup-marzban.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

log "=== Начало бэкапа ==="

# Создаём временную директорию
mkdir -p "${TEMP_DIR}/marzban-data"
mkdir -p "${TEMP_DIR}/marzban-stack"

# Бэкап SQLite базы данных (безопасный online-snapshot, работает без остановки контейнера)
log "Бэкап базы данных..."
sqlite3 "${MARZBAN_DATA}/db.sqlite3" ".backup '${TEMP_DIR}/db.sqlite3'"

# Бэкап остальных данных Marzban (xray-конфиги, сертификаты и т.д.)
log "Бэкап данных Marzban..."
rsync -a --exclude='db.sqlite3' "${MARZBAN_DATA}/" "${TEMP_DIR}/marzban-data/"

# Бэкап конфигурации стека (docker-compose, .env, Caddyfile)
log "Бэкап конфигурации стека..."
rsync -a --exclude='.git' "${STACK_DIR}/" "${TEMP_DIR}/marzban-stack/"

# Упаковываем всё в архив
log "Архивирование..."
tar -czf "/tmp/${BACKUP_NAME}.tar.gz" -C /tmp "${BACKUP_NAME}"

ARCHIVE_SIZE=$(du -sh "/tmp/${BACKUP_NAME}.tar.gz" | cut -f1)
log "Размер архива: ${ARCHIVE_SIZE}"

# Загружаем на Google Drive
log "Загрузка на Google Drive (${RCLONE_REMOTE})..."
rclone copy "/tmp/${BACKUP_NAME}.tar.gz" "${RCLONE_REMOTE}/"

# Удаляем бэкапы старше KEEP_DAYS дней
log "Удаление бэкапов старше ${KEEP_DAYS} дней..."
rclone delete "${RCLONE_REMOTE}/" --min-age "${KEEP_DAYS}d"

# Очищаем временные файлы
rm -rf "${TEMP_DIR}" "/tmp/${BACKUP_NAME}.tar.gz"

log "=== Бэкап завершён успешно: ${BACKUP_NAME}.tar.gz ==="
